# ─── Required ─────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ─── Bot Username (required for group commands to show correct DM link) ───────
# Your bot's @username WITHOUT the @ symbol
BOT_USERNAME=YourBotUsername

# ─── Force Subscribe (optional) ───────────────────────────────────────────────
# Users must join this channel before the bot works
CHANNEL_USERNAME=@YourChannel
FORCE_SUB=false

# ─── Optional ─────────────────────────────────────────────────────────────────
DEVELOPER_ID=your_telegram_user_id
WELCOME_IMAGE=https://files.tgvibes.online/Cz75r1D6.jpg
MAX_FILE_MB=512
